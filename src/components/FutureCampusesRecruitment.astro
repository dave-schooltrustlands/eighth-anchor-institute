---
// EPSILON — Future campuses recruitment band.
// Single prose paragraph + mailto CTA (v1.2 content).
const subject = encodeURIComponent('Future campuses — express interest');
---
<section id="future-campuses" class="bg-eai-bone">
  <div class="mx-auto max-w-3xl px-5 py-20 md:py-24">
    <p class="font-mono text-[11px] tracking-[0.22em] uppercase text-eai-gold mb-5">
      Future campuses
    </p>
    <h2 class="font-serif text-3xl md:text-4xl text-eai-navy mb-6">
      Reserved — under formation
    </h2>
    <p class="font-serif text-lg leading-relaxed text-eai-navy/90">
      The Institute is in its founding period. The School Trust Campus is
      operational; the five reserved campuses are open invitations to
      architects, foundations, and standing communities ready to do the
      founding work for their domain. Each reserved campus needs three
      things: founding scholarship to write what the school-trust record can
      teach about that trust type, an institutional sponsor to host the
      campus's first working artifacts, and a small standing community
      willing to be the seventh anchor's eighth piece — the people who hold
      the trust to its purpose across generations. If your work touches any
      of these domains, the Institute would like to hear from you.
    </p>
    <a
      href={`mailto:campus-interest@eighthanchor.org?subject=${subject}`}
      class="mt-8 inline-flex items-center gap-2 bg-eai-navy text-eai-parchment px-5 py-3 text-sm font-medium tracking-wide hover:bg-eai-green transition"
    >
      Express interest
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>
