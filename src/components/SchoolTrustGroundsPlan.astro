---
// ETA — School Trust Campus Grounds Plan.
// Literal map: four active building footprints, three reserved plots,
// labeled paths. Blueprint / architectural register.
import { buildings, reservedPlots, paths } from '../data/schoolTrustCampus.js';

const W = 1200;
const H = 720;
const FW = 200; // building footprint width
const FH = 110; // building footprint height
const RW = 130; // reserved plot width
const RH = 80;  // reserved plot height

function bx(percent: number, width: number) {
  return (percent / 100) * W - width / 2;
}
function by(percent: number, height: number) {
  return (percent / 100) * H - height / 2;
}

const byId = Object.fromEntries(
  buildings.map((b) => [b.id, { ...b, px: (b.x / 100) * W, py: (b.y / 100) * H }])
);

const statusFill: Record<string, string> = {
  active: '#B88A2E',
  allied: 'transparent',
  chapter: 'rgba(184,138,46,0.18)',
  reserved: 'transparent',
};
const statusStroke: Record<string, string> = {
  active: '#B88A2E',
  allied: '#536879',
  chapter: '#B88A2E',
  reserved: '#536879',
};
---
<div class="relative border border-eai-blueprint/40 bg-eai-parchment/40 bg-blueprint-grid">
  <svg viewBox={`0 0 ${W} ${H}`} class="w-full h-auto" role="img" aria-label="School Trust Campus Grounds Plan">
    <!-- PLSS-style baselines -->
    <line x1="0" y1={H / 2} x2={W} y2={H / 2} stroke="#536879" stroke-width="0.5" stroke-dasharray="2 6" opacity="0.5" />
    <line x1={W / 2} y1="0" x2={W / 2} y2={H} stroke="#536879" stroke-width="0.5" stroke-dasharray="2 6" opacity="0.5" />

    <!-- Corner section ticks — surveyor's quadrant markers -->
    <g stroke="#536879" stroke-width="0.8" opacity="0.55">
      <line x1="0" y1="0" x2="14" y2="0" /><line x1="0" y1="0" x2="0" y2="14" />
      <line x1={W} y1="0" x2={W - 14} y2="0" /><line x1={W} y1="0" x2={W} y2="14" />
      <line x1="0" y1={H} x2="14" y2={H} /><line x1="0" y1={H} x2="0" y2={H - 14} />
      <line x1={W} y1={H} x2={W - 14} y2={H} /><line x1={W} y1={H} x2={W} y2={H - 14} />
    </g>

    <!-- Paths between buildings -->
    {paths.map((p) => {
      const a = byId[p.from];
      const b = byId[p.to];
      if (!a || !b) return null;
      const mx = (a.px + b.px) / 2;
      const my = (a.py + b.py) / 2;
      return (
        <g>
          <line
            x1={a.px}
            y1={a.py}
            x2={b.px}
            y2={b.py}
            stroke="#536879"
            stroke-width="0.7"
            stroke-dasharray="5 4"
            opacity="0.7"
          />
          <rect
            x={mx - 70}
            y={my - 10}
            width="140"
            height="20"
            fill="#F4EFE4"
            opacity="0.95"
          />
          <text
            x={mx}
            y={my + 4}
            text-anchor="middle"
            font-family="IBM Plex Mono, monospace"
            font-size="10"
            letter-spacing="1.5"
            fill="#536879"
            style="text-transform: uppercase"
          >
            {p.label}
          </text>
        </g>
      );
    })}

    <!-- Reserved plots -->
    {reservedPlots.map((plot) => {
      const rx = bx(plot.x, RW);
      const ry = by(plot.y, RH);
      return (
        <g class="reserved-plot" data-plot-id={plot.id} style="cursor: pointer" tabindex="0" role="button" aria-label={plot.label}>
          <rect
            x={rx}
            y={ry}
            width={RW}
            height={RH}
            fill="transparent"
            stroke="#536879"
            stroke-width="0.8"
            stroke-dasharray="4 3"
          />
          <text
            x={rx + RW / 2}
            y={ry + RH / 2 - 4}
            text-anchor="middle"
            font-family="IBM Plex Mono, monospace"
            font-size="9"
            letter-spacing="1.5"
            fill="#536879"
            style="text-transform: uppercase"
          >
            Reserved
          </text>
          <text
            x={rx + RW / 2}
            y={ry + RH / 2 + 12}
            text-anchor="middle"
            font-family="Cormorant Garamond, serif"
            font-size="14"
            fill="#0E1A24"
          >
            {plot.short || plot.label.replace('Reserved plot: ', '')}
          </text>
        </g>
      );
    })}

    <!-- Active building footprints -->
    {buildings.map((b) => {
      const rx = bx(b.x, FW);
      const ry = by(b.y, FH);
      return (
        <g class="building-footprint" data-building-id={b.id} style="cursor: pointer">
          <rect
            x={rx}
            y={ry}
            width={FW}
            height={FH}
            fill={statusFill[b.status] || 'transparent'}
            stroke={statusStroke[b.status] || '#536879'}
            stroke-width={b.status === 'active' ? '1.3' : '1'}
          />
          <text
            x={rx + FW / 2}
            y={ry + 22}
            text-anchor="middle"
            font-family="IBM Plex Mono, monospace"
            font-size="10"
            letter-spacing="1.8"
            fill={b.status === 'active' ? '#0E1A24' : '#536879'}
            style="text-transform: uppercase"
          >
            {b.address}
          </text>
          <text
            x={rx + FW / 2}
            y={ry + 50}
            text-anchor="middle"
            font-family="Cormorant Garamond, serif"
            font-size="20"
            fill="#0E1A24"
          >
            {b.short}
          </text>
          <text
            x={rx + FW / 2}
            y={ry + 78}
            text-anchor="middle"
            font-family="IBM Plex Mono, monospace"
            font-size="10"
            fill="#536879"
          >
            {b.domain}
          </text>
        </g>
      );
    })}
  </svg>

  <div class="absolute top-2 left-2 font-mono text-[9px] tracking-widest text-eai-blueprint/70 uppercase">
    Plan №2 — School Trust Campus
  </div>
  <div class="absolute bottom-2 right-2 font-mono text-[9px] tracking-widest text-eai-blueprint/70 uppercase">
    Literal · v1 · 2026
  </div>
</div>

<!-- Reserved-plot recruitment modal -->
<div
  id="plot-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-eai-navy/70 px-5"
  role="dialog"
  aria-modal="true"
  aria-labelledby="plot-modal-title"
>
  <div class="bg-eai-bone max-w-lg w-full p-6 border border-eai-blueprint/40 shadow-2xl">
    <div class="flex items-start justify-between gap-4">
      <p class="font-mono text-[10px] tracking-[0.22em] uppercase text-eai-gold">
        Reserved plot
      </p>
      <button id="plot-modal-close" class="text-eai-blueprint hover:text-eai-navy text-xl leading-none" aria-label="Close">&times;</button>
    </div>
    <h3 id="plot-modal-title" class="font-serif text-2xl text-eai-navy mt-1"></h3>
    <p id="plot-modal-why" class="mt-3 text-sm leading-relaxed text-eai-navy/85"></p>
    <div class="mt-5 flex flex-wrap items-center gap-3">
      <a
        id="plot-modal-cta"
        href="mailto:campus-interest@eighthanchor.org"
        class="inline-flex items-center gap-2 bg-eai-navy text-eai-parchment px-4 py-2 text-sm hover:bg-eai-green transition"
      >
        <span id="plot-modal-cta-label">Help break ground</span>
        <span aria-hidden="true">→</span>
      </a>
      <button id="plot-modal-close-2" class="text-sm text-eai-blueprint hover:text-eai-navy underline decoration-eai-blueprint/40">
        Close
      </button>
    </div>
  </div>
</div>

<script type="module" is:inline define:vars={{ plots: reservedPlots }}>
  document.querySelectorAll('.building-footprint').forEach((el) => {
    el.addEventListener('click', () => {
      const id = el.getAttribute('data-building-id');
      if (!id) return;
      const target = document.getElementById(`building-${id}`);
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  });

  const modal = document.getElementById('plot-modal');
  const title = document.getElementById('plot-modal-title');
  const why = document.getElementById('plot-modal-why');
  const cta = document.getElementById('plot-modal-cta');
  const ctaLabel = document.getElementById('plot-modal-cta-label');

  function openPlot(id) {
    const p = plots.find((p) => p.id === id);
    if (!p) return;
    title.textContent = p.short || p.label.replace('Reserved plot: ', '');
    why.textContent = p.why || '';
    ctaLabel.textContent = p.cta || 'Help break ground';
    const subject = encodeURIComponent(p.contactSubject || p.label);
    cta.href = `mailto:campus-interest@eighthanchor.org?subject=${subject}`;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }
  function closePlot() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  document.querySelectorAll('.reserved-plot').forEach((el) => {
    el.addEventListener('click', () => {
      const id = el.getAttribute('data-plot-id');
      if (id) openPlot(id);
    });
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const id = el.getAttribute('data-plot-id');
        if (id) openPlot(id);
      }
    });
  });

  document.getElementById('plot-modal-close')?.addEventListener('click', closePlot);
  document.getElementById('plot-modal-close-2')?.addEventListener('click', closePlot);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closePlot();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closePlot();
  });
</script>
