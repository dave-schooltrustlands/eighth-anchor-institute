---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThesisHero from '../components/ThesisHero.astro';
import WhyThisExists from '../components/WhyThisExists.astro';
import ArchivalBand from '../components/ArchivalBand.astro';
import InstituteGroundsPlan from '../components/InstituteGroundsPlan.astro';
import FoundingTexts from '../components/FoundingTexts.astro';
import FutureCampusesRecruitment from '../components/FutureCampusesRecruitment.astro';
---
<BaseLayout
  title="The Eighth Anchor Institute — for Intergenerational Trust Design"
  description="A civic institution studying how multi-generational trusts survive, fail, and recover — beginning with America's school trust lands and extending to AI governance, climate adaptation, treaty obligations, and public endowments."
  path="/"
  ogTitle="The Eighth Anchor Institute"
  ogDescription="Long-horizon trusts fail when obligation loses its architecture. We study the only 240-year record we have."
>
  <ThesisHero />
  <WhyThisExists />
  <ArchivalBand />
  <InstituteGroundsPlan />
  <FoundingTexts />
  <FutureCampusesRecruitment />
</BaseLayout>
